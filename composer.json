{
    "name": "psc-acme/toolkit-order",
    "description": "Package toolkit-order for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ToolkitOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "league/commonmark": "^2.0",
        "nesbot/carbon": "^2.72",
        "vlucas/phpdotenv": "^5.0",
        "symfony/console": "^7.0",
        "doctrine/doctrine-bundle": "^2.13",
        "psr/container": "^2.0",
        "psc-acme/encoder-billing": "^1.0",
        "psc-acme/helper-order": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan-symfony": "^1.0",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}